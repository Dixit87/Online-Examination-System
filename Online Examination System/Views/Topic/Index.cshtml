@model IEnumerable<Online_Examination_System.Models.Topic>
@{
    ViewData["Title"] = "Manage Topics";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Topics</h1>
    <a asp-action="Upsert" class="btn btn-sm btn-primary shadow-sm rounded-pill px-3 py-2">
        <i class="bi bi-plus-circle fa-sm text-white-50"></i> Create New
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card premium-card mb-4">
    <div class="card-header py-3 bg-white border-0 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary">All Topics</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="dataTable" class="table table-hover align-middle mb-0 border-white">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Session</th>
                        <th>Chapter</th>
                        <th>Topic Title</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><span class="badge bg-info text-dark">@item.SessionTitle</span></td>
                                <td><span class="badge bg-secondary">@item.ChapterTitle</span></td>
                                <td><div class="fw-bold text-dark">@item.Title</div></td>
                                <td>@item.TopicType</td>
                                <td>
                                    <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" class="m-0 p-0">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" onchange="this.form.submit()" @(item.Status ? "checked" : "")>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <a asp-action="Upsert" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "info": true
            });
        });
    </script>
}
