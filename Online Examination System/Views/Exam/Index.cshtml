@model IEnumerable<Online_Examination_System.Models.Exam>
@{
    ViewData["Title"] = "Exam Management";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Exam Management</h1>
    <a asp-action="Upsert" class="btn btn-sm btn-primary shadow-sm rounded-pill px-3 py-2">
        <i class="bi bi-plus-circle fa-sm text-white-50"></i> Create New Exam
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card premium-card mb-4">
    <div class="card-header py-3 bg-white border-0 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary">All Exams</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 border-white">
                <thead class="table-light">
                    <tr>
                        <th>Exam Title</th>
                        <th>Exam Type</th>
                        <th>Questions</th>
                        <th>Total Marks</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><div class="fw-bold text-dark">@item.ExamTitle</div></td>
                                <td><span class="badge bg-secondary rounded-pill px-3 py-2">@item.ExamTypeName</span></td>
                                <td>@item.NoOfQuestions</td>
                                <td>@item.TotalMark</td>
                                <td>
                                    <form asp-action="ToggleStatus" asp-route-id="@item.ExamId" method="post" class="m-0 p-0">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" onchange="this.form.submit()" @(item.IsActive ? "checked" : "")>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <a asp-action="Upsert" asp-route-id="@item.ExamId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No exams found. Click 'Create New Exam' to add one.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
