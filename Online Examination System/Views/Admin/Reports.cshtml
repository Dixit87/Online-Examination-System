@model Online_Examination_System.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Reports & Analytics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Reports & Analytics</h1>
    <a href="#" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm rounded-pill px-3 py-2">
        <i class="bi bi-download fa-sm text-white-50 me-1"></i> Download Report
    </a>
</div>

<!-- Core Metrics Row -->
<div class="row g-4 mb-4">
    <!-- Total Users -->
    <div class="col-xl-3 col-md-6">
        <div class="card premium-card border-0 shadow-sm h-100 bg-white">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-uppercase text-muted fw-bold mb-1 fs-7" style="letter-spacing: 1px;">Total Users</p>
                        <h2 class="mb-0 fw-bolder text-dark">@Model.TotalUsers</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-people-fill text-primary fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Students -->
    <div class="col-xl-3 col-md-6">
        <div class="card premium-card border-0 shadow-sm h-100 bg-white">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-uppercase text-muted fw-bold mb-1 fs-7" style="letter-spacing: 1px;">Total Students</p>
                        <h2 class="mb-0 fw-bolder text-dark">@Model.TotalStudents</h2>
                    </div>
                    <div class="bg-info bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-mortarboard-fill text-info fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Exams -->
    <div class="col-xl-3 col-md-6">
        <div class="card premium-card border-0 shadow-sm h-100 bg-white">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-uppercase text-muted fw-bold mb-1 fs-7" style="letter-spacing: 1px;">Total Exams</p>
                        <h2 class="mb-0 fw-bolder text-dark">@Model.TotalExams</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-journal-text text-warning fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Questions -->
    <div class="col-xl-3 col-md-6">
        <div class="card premium-card border-0 shadow-sm h-100 bg-white">
            <div class="card-body p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-uppercase text-muted fw-bold mb-1 fs-7" style="letter-spacing: 1px;">Total Questions</p>
                        <h2 class="mb-0 fw-bolder text-dark">@Model.TotalQuestions</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                        <i class="bi bi-question-square-fill text-success fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Performance Metrics Row -->
<div class="row g-4 mb-4">
    <!-- Completed Exams -->
    <div class="col-lg-4">
        <div class="card premium-card border-0 shadow-sm h-100 bg-white text-center">
            <div class="card-body p-5">
                <div class="bg-secondary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px;">
                    <i class="bi bi-check-all text-secondary" style="font-size: 2.5rem;"></i>
                </div>
                <h2 class="fw-bolder display-5 text-dark mb-1">@Model.CompletedExams</h2>
                <p class="text-muted fw-bold text-uppercase mb-0" style="letter-spacing: 1px;">Completed Exams</p>
            </div>
        </div>
    </div>

    <!-- Performance Breakdown -->
    <div class="col-lg-8">
        <div class="card premium-card border-0 shadow-sm h-100 bg-white">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold text-dark mb-0"><i class="bi bi-bar-chart-steps text-primary me-2"></i> Performance Overview</h5>
            </div>
            <div class="card-body p-4">
                <div class="row align-items-center h-100">
                    
                    <!-- Passed Students -->
                    <div class="col-md-6 mb-4 mb-md-0 border-md-end border-light">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <div>
                                <span class="text-success fw-bold"><i class="bi bi-trophy-fill me-1"></i> Passed Students</span>
                                <h3 class="fw-bolder text-dark mb-0 mt-1">@Model.PassedStudents</h3>
                            </div>
                            <div class="text-end">
                                <h4 class="text-success fw-bolder mb-0">@Model.PassPercentage.ToString("0.##")%</h4>
                            </div>
                        </div>
                        <div class="progress" style="height: 10px; border-radius: 5px;">
                            <div class="progress-bar bg-success progress-bar-striped progress-bar-animated" role="progressbar" style="width: @Model.PassPercentage%" aria-valuenow="@Model.PassPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <!-- Failed Students -->
                    <div class="col-md-6 ps-md-4">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <div>
                                <span class="text-danger fw-bold"><i class="bi bi-x-octagon-fill me-1"></i> Failed Students</span>
                                <h3 class="fw-bolder text-dark mb-0 mt-1">@Model.FailedStudents</h3>
                            </div>
                            <div class="text-end">
                                <h4 class="text-danger fw-bolder mb-0">@Model.FailPercentage.ToString("0.##")%</h4>
                            </div>
                        </div>
                        <div class="progress" style="height: 10px; border-radius: 5px;">
                            <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: @Model.FailPercentage%" aria-valuenow="@Model.FailPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fs-7 { font-size: 0.8rem; }
    .premium-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .premium-card:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.1) !important; }
    .border-md-end { border-right: 1px solid #e9ecef; }
</style>
