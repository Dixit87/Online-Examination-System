<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online Exam System</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Online_Examination_System.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <i class="bi bi-mortarboard-fill text-primary"></i>
                <span>ExamPro</span>
            </div>
            
            <ul class="list-unstyled components">
                <p class="sidebar-heading">Main Menu</p>
                
                @if (User.IsInRole("Admin"))
                {
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                        <a href="/" class="nav-link">
                            <i class="bi bi-grid-1x2-fill"></i> Dashboard
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "ExamType" ? "active" : "")">
                        <a href="@Url.Action("Index", "ExamType")" class="nav-link">
                            <i class="bi bi-tags"></i> Manage Exam Types
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Question" ? "active" : "")">
                        <a href="@Url.Action("Index", "Question")" class="nav-link">
                            <i class="bi bi-database-fill"></i> Question Bank
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Exam" ? "active" : "")">
                        <a href="@Url.Action("Index", "Exam")" class="nav-link">
                            <i class="bi bi-journal-check"></i> Manage Exams
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Student" ? "active" : "")">
                        <a href="@Url.Action("Index", "Student")" class="nav-link">
                            <i class="bi bi-person-video2"></i> Manage Students
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                        <a href="@Url.Action("Users", "Admin")" class="nav-link">
                            <i class="bi bi-people-fill"></i> Manage Users
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("Reports", "Admin")" class="nav-link">
                            <i class="bi bi-bar-chart-fill"></i> Results & Reports
                        </a>
                    </li>
                }
                else if (User.IsInRole("Student"))
                {
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudentPanel" && ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")">
                        <a href="@Url.Action("Dashboard", "StudentPanel")" class="nav-link">
                            <i class="bi bi-grid-1x2-fill"></i> Student Dashboard
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudentPanel" && ViewContext.RouteData.Values["Action"]?.ToString() == "Exams" ? "active" : "")">
                        <a href="@Url.Action("Exams", "StudentPanel")" class="nav-link">
                            <i class="bi bi-card-list"></i> Exam List
                        </a>
                    </li>
                    <li class ="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudentPanel" && ViewContext.RouteData.Values["Action"]?.ToString() == "TakeExam" ? "active" : "")">
                        <a href="#" class="nav-link text-muted pe-none">
                            <i class="bi bi-laptop"></i> Exam Screen (Auto)
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudentPanel" && ViewContext.RouteData.Values["Action"]?.ToString() == "Result" ? "active" : "")">
                        <a href="#" class="nav-link text-muted pe-none">
                            <i class="bi bi-award-fill"></i> Result (Auto)
                        </a>
                    </li>
                    <li class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "StudentPanel" && ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                        <a href="@Url.Action("Profile", "StudentPanel")" class="nav-link">
                            <i class="bi bi-person-circle"></i> Student Profile
                        </a>
                    </li>
                }

                <p class="sidebar-heading mt-4">Settings</p>
                @if (User.IsInRole("Admin"))
                {
                    <li>
                        <a href="#" class="nav-link">
                            <i class="bi bi-gear-fill"></i> System Settings
                        </a>
                    </li>
                }
                <li>
                    <a href="@Url.Action("Logout", "Account")" class="nav-link text-danger">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Page Content -->
        <div id="content" class="w-100">
            <!-- Topbar -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white topbar shadow-sm">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-light shadow-sm">
                        <i class="bi bi-list fs-5"></i>
                    </button>
                    
                    <div class="d-flex align-items-center ms-auto">
                        <!-- Notifications -->
                        <div class="dropdown me-3">
                            <a class="nav-link dropdown-toggle hidden-arrow" href="#" id="navbarDropdownMenuLink" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-bell fs-5"></i>
                                <span class="badge rounded-pill badge-notification bg-danger" style="position:absolute; top:0; right:-5px; font-size: 0.6rem;">1</span>
                            </a>
                        </div>
                        
                        <!-- Avatar -->
                        <div class="dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center hidden-arrow" href="#" id="navbarDropdownMenuAvatar" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @{
                                    var userName = User.Identity?.Name ?? "User";
                                }
                                <img src="https://ui-avatars.com/api/?name=@userName&background=0D8ABC&color=fff" class="rounded-circle" height="35" alt="Avatar" loading="lazy" />
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="navbarDropdownMenuAvatar">
                                <li><a class="dropdown-item" href="#">My profile</a></li>
                                <li><a class="dropdown-item" href="#">Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">Logout</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <!-- Main Body -->
            <main class="p-4 bg-light main-content-area">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Sidebar Toggle Script -->
    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
