@model IEnumerable<Online_Examination_System.Models.User>
@{
    ViewData["Title"] = "Student Management";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Student Management</h1>
</div>

<div class="card premium-card mb-4 shadow-sm border-0">
    <div class="card-header py-3 bg-white border-0 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary">All Students</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 border-white">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Contact</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var student in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <img src="https://ui-avatars.com/api/?name=@student.Name&background=random&color=fff" class="rounded-circle me-3" height="35" alt="Avatar" />
                                        <div class="fw-bold text-dark">@student.Name</div>
                                    </div>
                                </td>
                                <td>@student.Username</td>
                                <td>@student.Email</td>
                                <td>@student.Contact</td>
                                <td>
                                    @if(student.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill px-3 py-2">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill px-3 py-2">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@student.UserId" class="btn btn-sm btn-outline-info shadow-sm rounded-pill px-3">
                                        <i class="bi bi-eye me-1"></i> View Details
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No students found in the system.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
