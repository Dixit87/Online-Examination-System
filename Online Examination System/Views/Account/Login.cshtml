@model Online_Examination_System.ViewModels.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-xl-5 col-lg-6 col-md-8">
        <div class="card auth-card">
            <div class="auth-header">
                <h3 class="mb-0 fw-bold">Online Examination System</h3>
                <p class="text-white-50 mb-0">Welcome Back!</p>
            </div>
            <div class="auth-body">
                <div class="text-center mb-4">
                    <h4 class="text-dark fw-bold">Login to Your Account</h4>
                </div>

                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="UsernameOrEmail" class="form-control rounded-pill px-4" placeholder="Username or Email" />
                        <label asp-for="UsernameOrEmail" class="ms-2">Username or Email</label>
                        <span asp-validation-for="UsernameOrEmail" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control rounded-pill px-4" placeholder="Password" />
                        <label asp-for="Password" class="ms-2">Password</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
                        <a href="#" class="small text-decoration-none">Forgot Password?</a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow-sm">
                        Login
                    </button>
                </form>

                <hr class="my-4">
                
                <div class="text-center">
                    <span class="small text-muted">Don't have an account?</span>
                    <a asp-action="Register" class="small text-decoration-none fw-bold">Create an Account!</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
