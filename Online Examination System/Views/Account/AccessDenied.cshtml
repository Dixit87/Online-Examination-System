@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Access Denied";
}

<div class="row justify-content-center">
    <div class="col-xl-5 col-lg-6 col-md-8 text-center">
        <div class="card auth-card mt-5">
            <div class="auth-body py-5">
                <i class="bi bi-shield-lock-fill text-danger mb-4" style="font-size: 5rem;"></i>
                <h1 class="h3 mb-3 font-weight-bold text-dark">Access Denied</h1>
                <p class="text-muted mb-4">
                    You do not have permission to access this page. <br />
                    Only users with the <strong>Admin</strong> role can view this section.
                </p>
                
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-sm">
                    Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
