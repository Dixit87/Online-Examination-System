@model IEnumerable<Online_Examination_System.Models.Topic>
@{
    ViewData["Title"] = "Topics - " + ViewBag.ChapterTitle;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1 text-gray-800 font-weight-800">@ViewBag.ChapterTitle</h1>
        <p class="text-muted mb-0"><span class="badge bg-primary me-2">@ViewBag.SessionTitle</span> Select a topic to view its content.</p>
    </div>
    <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary rounded-pill px-3 py-2 shadow-sm">
        <i class="bi bi-arrow-left"></i> Back to Chapters
    </a>
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var topic in Model.OrderBy(t => t.TopicPosition))
        {
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card premium-card border-0 shadow-sm h-100 hover-lift">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="icon-circle bg-warning-subtle text-warning">
                                @if (topic.TopicType == "General")
                                {
                                    <i class="bi bi-file-earmark-text fs-4"></i>
                                }
                                else if (topic.TopicType == "Accordion")
                                {
                                    <i class="bi bi-ui-radios fs-4"></i>
                                }
                                else
                                {
                                    <i class="bi bi-images fs-4"></i>
                                }
                            </div>
                            @if (topic.DurationMin.HasValue && topic.DurationMin > 0)
                            {
                                <span class="badge bg-light text-dark border"><i class="bi bi-clock me-1"></i> @topic.DurationMin mins</span>
                            }
                        </div>
                        <h5 class="fw-bold text-dark mb-2">@topic.Title</h5>
                        <p class="text-muted small flex-grow-1">
                            @(string.IsNullOrEmpty(topic.Description) ? "No description available." : topic.Description)
                        </p>
                        <a href="@Url.Action("TopicDetails", new { topicId = topic.Id })" class="btn btn-outline-warning text-dark btn-sm rounded-pill mt-3 fw-bold w-100 border-warning">
                            Start Learning <i class="bi bi-play-circle ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info border-0 shadow-sm rounded-4 text-center p-5">
                <i class="bi bi-journal-x display-4 text-info mb-3 d-block"></i>
                <h5 class="fw-bold">No Topics Found</h5>
                <p class="text-muted">There are currently no topics available for this chapter.</p>
            </div>
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
