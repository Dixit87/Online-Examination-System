@model Online_Examination_System.ViewModels.ExamResultViewModel
@{
    ViewData["Title"] = "Exam Result";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Exam Result</h1>
    <a href="@Url.Action("Exams", "StudentPanel")" class="d-none d-sm-inline-block btn btn-sm btn-outline-secondary shadow-sm rounded-pill px-3 py-2">
        <i class="bi bi-arrow-left fa-sm me-1"></i> Back to Exam List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card premium-card shadow-sm border-0 mb-4 position-relative overflow-hidden">
            <!-- Pass/Fail Banner Top Border -->
            <div class="position-absolute w-100 top-0 start-0" style="height: 5px; background-color: @(Model.PassStatus == "PASS" ? "#198754" : "#dc3545");"></div>
            
            <div class="card-body p-5">
                <!-- Status Badge Large -->
                <div class="text-center mb-5">
                    @if (Model.PassStatus == "PASS")
                    {
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-trophy-fill text-success" style="font-size: 2.5rem;"></i>
                        </div>
                        <h2 class="font-weight-bold text-success mb-1">Congratulations! You Passed</h2>
                    }
                    else
                    {
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-x-circle-fill text-danger" style="font-size: 2.5rem;"></i>
                        </div>
                        <h2 class="font-weight-bold text-danger mb-1">Better Luck Next Time</h2>
                    }
                    <div class="text-muted fs-5">You scored @Model.Score out of @Model.TotalMarks</div>
                </div>

                <!-- Grid Details -->
                <div class="row g-4">
                    <!-- Column 1 -->
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush border-top border-bottom">
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Exam Type</span>
                                <span class="text-dark fw-bold">@Model.ExamTypeName</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Exam Name</span>
                                <span class="text-dark fw-bold">@Model.ExamName</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Total Questions</span>
                                <span class="text-dark fw-bold">@Model.TotalQuestions</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Passing Marks</span>
                                <span class="text-dark fw-bold">@Model.PassingMarks</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold"><i class="bi bi-award-fill text-warning me-1"></i> Your Rank</span>
                                <span class="text-dark fw-bold">@Model.Rank <span class="text-muted small">out of @Model.TotalParticipants</span></span>
                            </li>
                        </ul>
                    </div>

                    <!-- Column 2 -->
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush border-top border-bottom">
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Attempted Questions</span>
                                <span class="text-dark fw-bold">@Model.TotalAttemptedQuestions</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Correct Answers</span>
                                <span class="text-success fw-bold">@Model.TotalCorrectAnswers</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Wrong Answers</span>
                                <span class="text-danger fw-bold">@Model.TotalWrongAnswers</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Percentage</span>
                                <span class="text-dark fw-bold fs-5">@Model.ResultPercentage.ToString("0.##")%</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Footer details -->
                <div class="mt-4 text-center text-muted small">
                    <div>Exam Started: @Model.ExamStartDate.ToString("MMM dd, yyyy hh:mm tt")</div>
                    @if (Model.ExamFinishDate.HasValue)
                    {
                        <div>Exam Finished: @Model.ExamFinishDate.Value.ToString("MMM dd, yyyy hh:mm tt")</div>
                    }
                </div>

                @if (Model.PassStatus == "PASS")
                {
                    <div class="mt-5 text-center">
                        <button id="btnDownloadCert" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow">
                            <i class="bi bi-file-earmark-pdf-fill me-2"></i> Download Certificate
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Hidden Certificate Template -->
<div id="certificateTemplate" style="display: none;">
    <div style="width: 800px; height: 600px; padding: 20px; text-align: center; border: 10px solid #787878; border-radius: 10px; background-color: #fff; font-family: 'Georgia', serif; position: relative;">
        <div style="position: absolute; top: 10px; left: 10px; right: 10px; bottom: 10px; border: 2px solid #d4af37; border-radius: 5px;"></div>
        <div style="padding-top: 50px;">
            <i class="bi bi-award-fill" style="font-size: 5rem; color: #d4af37;"></i>
            <h1 style="font-size: 50px; font-weight: bold; margin-top: 20px; color: #333;">CERTIFICATE</h1>
            <h2 style="font-size: 24px; font-style: italic; color: #666; margin-bottom: 40px;">OF ACHIEVEMENT</h2>
            
            <p style="font-size: 18px; color: #555;">This is to certify that</p>
            <h3 style="font-size: 32px; font-weight: bold; color: #000; text-decoration: underline; margin-bottom: 30px;">
                @User.Identity.Name
            </h3>
            
            <p style="font-size: 18px; color: #555;">has successfully completed the exam</p>
            <h4 style="font-size: 24px; font-weight: bold; color: #333; margin-bottom: 20px;">
                @Model.ExamName
            </h4>
            
            <p style="font-size: 18px; color: #555;">with a passing score of <strong>@Model.ResultPercentage.ToString("0.##")%</strong>.</p>
            
            <div style="margin-top: 50px; display: flex; justify-content: space-between; padding: 0 100px;">
                <div style="text-align: center;">
                    <div style="border-bottom: 1px solid #333; width: 150px; margin-bottom: 5px; height: 30px; font-family: 'Courier New', Courier, monospace;">
                        @DateTime.Now.ToString("dd MMM yyyy")
                    </div>
                    <span style="font-size: 14px; color: #777;">Date of Issue</span>
                </div>
                <div style="text-align: center;">
                    <div style="border-bottom: 1px solid #333; width: 150px; margin-bottom: 5px; height: 30px; font-family: 'Courier New', Courier, monospace; font-style: italic;">
                        OES Admin
                    </div>
                    <span style="font-size: 14px; color: #777;">Authorized Signature</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Include html2pdf.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var btnDownload = document.getElementById('btnDownloadCert');
            if (btnDownload) {
                btnDownload.addEventListener('click', function () {
                    var element = document.getElementById('certificateTemplate');
                    // Temporarily show the element to render it
                    element.style.display = 'block';

                    var opt = {
                        margin:       0,
                        filename:     'Certificate_@(Model.ExamName.Replace(" ", "_")).pdf',
                        image:        { type: 'jpeg', quality: 0.98 },
                        html2canvas:  { scale: 2 },
                        jsPDF:        { unit: 'in', format: 'letter', orientation: 'landscape' }
                    };

                    // New Promise-based usage:
                    html2pdf().set(opt).from(element.children[0]).save().then(function() {
                        // Hide it again
                        element.style.display = 'none';
                    });
                });
            }
        });
    </script>
}
