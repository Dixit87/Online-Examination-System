@model Online_Examination_System.ViewModels.ExamResultViewModel
@{
    ViewData["Title"] = "Exam Result";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Exam Result</h1>
    <a href="@Url.Action("Exams", "StudentPanel")" class="d-none d-sm-inline-block btn btn-sm btn-outline-secondary shadow-sm rounded-pill px-3 py-2">
        <i class="bi bi-arrow-left fa-sm me-1"></i> Back to Exam List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card premium-card shadow-sm border-0 mb-4 position-relative overflow-hidden">
            <!-- Pass/Fail Banner Top Border -->
            <div class="position-absolute w-100 top-0 start-0" style="height: 5px; background-color: @(Model.PassStatus == "PASS" ? "#198754" : "#dc3545");"></div>
            
            <div class="card-body p-5">
                <!-- Status Badge Large -->
                <div class="text-center mb-5">
                    @if (Model.PassStatus == "PASS")
                    {
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-success bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-trophy-fill text-success" style="font-size: 2.5rem;"></i>
                        </div>
                        <h2 class="font-weight-bold text-success mb-1">Congratulations! You Passed</h2>
                    }
                    else
                    {
                        <div class="d-inline-flex align-items-center justify-content-center rounded-circle bg-danger bg-opacity-10 mb-3" style="width: 80px; height: 80px;">
                            <i class="bi bi-x-circle-fill text-danger" style="font-size: 2.5rem;"></i>
                        </div>
                        <h2 class="font-weight-bold text-danger mb-1">Better Luck Next Time</h2>
                    }
                    <div class="text-muted fs-5">You scored @Model.Score out of @Model.TotalMarks</div>
                </div>

                <!-- Grid Details -->
                <div class="row g-4">
                    <!-- Column 1 -->
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush border-top border-bottom">
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Exam Type</span>
                                <span class="text-dark fw-bold">@Model.ExamTypeName</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Exam Name</span>
                                <span class="text-dark fw-bold">@Model.ExamName</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Total Questions</span>
                                <span class="text-dark fw-bold">@Model.TotalQuestions</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Passing Marks</span>
                                <span class="text-dark fw-bold">@Model.PassingMarks</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Column 2 -->
                    <div class="col-md-6">
                        <ul class="list-group list-group-flush border-top border-bottom">
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Attempted Questions</span>
                                <span class="text-dark fw-bold">@Model.TotalAttemptedQuestions</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Correct Answers</span>
                                <span class="text-success fw-bold">@Model.TotalCorrectAnswers</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Wrong Answers</span>
                                <span class="text-danger fw-bold">@Model.TotalWrongAnswers</span>
                            </li>
                            <li class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">
                                <span class="text-muted fw-bold">Percentage</span>
                                <span class="text-dark fw-bold fs-5">@Model.ResultPercentage.ToString("0.##")%</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Footer details -->
                <div class="mt-4 text-center text-muted small">
                    <div>Exam Started: @Model.ExamStartDate.ToString("MMM dd, yyyy hh:mm tt")</div>
                    @if (Model.ExamFinishDate.HasValue)
                    {
                        <div>Exam Finished: @Model.ExamFinishDate.Value.ToString("MMM dd, yyyy hh:mm tt")</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
