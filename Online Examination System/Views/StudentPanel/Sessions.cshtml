@model IEnumerable<Online_Examination_System.Models.Session>
@{
    ViewData["Title"] = "Course Materials - Sessions";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Course Materials</h1>
    <span class="badge bg-primary px-3 py-2 fs-6 rounded-pill shadow-sm">
        <i class="bi bi-book me-1"></i> Available Sessions
    </span>
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var session in Model)
        {
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card premium-card border-0 shadow-sm h-100 hover-lift">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="icon-circle bg-primary-subtle text-primary">
                                <i class="bi bi-calendar3 fs-4"></i>
                            </div>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">@session.Title</h5>
                        <p class="text-muted small flex-grow-1">
                            @(string.IsNullOrEmpty(session.Description) ? "No description available." : session.Description)
                        </p>
                        <a href="@Url.Action("Chapters", new { sessionId = session.Id })" class="btn btn-outline-primary btn-sm rounded-pill mt-3 fw-bold w-100">
                            View Chapters <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info border-0 shadow-sm rounded-4 text-center p-5">
                <i class="bi bi-info-circle display-4 text-info mb-3 d-block"></i>
                <h5 class="fw-bold">No Course Materials Available</h5>
                <p class="text-muted">There are currently no sessions assigned or active.</p>
            </div>
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
