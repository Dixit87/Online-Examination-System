@model Online_Examination_System.Models.Topic
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1 text-gray-800 font-weight-800">@Model.Title</h1>
        <p class="text-muted mb-0">
            <span class="badge bg-primary me-1">@ViewBag.SessionTitle</span>
            <span class="badge bg-secondary me-2">@ViewBag.ChapterTitle</span>
            @if (Model.DurationMin.HasValue && Model.DurationMin > 0)
            {
                <span class="badge bg-light text-dark border"><i class="bi bi-clock me-1"></i> @Model.DurationMin mins</span>
            }
        </p>
    </div>
    <a href="javascript:history.back()" class="btn btn-sm btn-outline-secondary rounded-pill px-3 py-2 shadow-sm">
        <i class="bi bi-arrow-left"></i> Back to Topics
    </a>
</div>

<div class="row">
    <div class="col-12 mb-4">
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="card premium-card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <p class="m-0 text-dark">@Model.Description</p>
                </div>
            </div>
        }

        <!-- CONTENT RENDERING -->
        <div class="card premium-card border-0 shadow-sm">
            <div class="card-body p-0">
                @if (Model.TopicType == "General")
                {
                    <div class="p-4 text-center">
                        @RenderMedia(Model.TopicFileType, Model.TopicFilePath)
                    </div>
                }
                else if (Model.TopicType == "Accordion")
                {
                    <div class="accordion accordion-flush" id="topicAccordion">
                        @for (int i = 0; i < Model.TopicDetails.Count; i++)
                        {
                            var detail = Model.TopicDetails[i];
                            <div class="accordion-item border-bottom">
                                <h2 class="accordion-header" id="heading_@i">
                                    <button class="accordion-button @(i == 0 ? "" : "collapsed") fw-bold text-primary" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_@i" aria-expanded="@(i == 0 ? "true" : "false")" aria-controls="collapse_@i">
                                        @detail.Title
                                        @if (detail.DurationMin.HasValue)
                                        {
                                            <span class="badge bg-light text-dark ms-2 border fw-normal">@detail.DurationMin mins</span>
                                        }
                                    </button>
                                </h2>
                                <div id="collapse_@i" class="accordion-collapse collapse @(i == 0 ? "show" : "")" aria-labelledby="heading_@i" data-bs-parent="#topicAccordion">
                                    <div class="accordion-body">
                                        @if (!string.IsNullOrEmpty(detail.Description))
                                        {
                                            <p class="text-muted mb-3">@detail.Description</p>
                                        }
                                        <div class="text-center bg-light p-3 rounded">
                                            @RenderMedia(detail.FileType, detail.FilePath)
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (Model.TopicType == "Multi Slider")
                {
                    <div id="topicCarousel" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-inner bg-dark rounded">
                            @for (int i = 0; i < Model.TopicDetails.Count; i++)
                            {
                                var detail = Model.TopicDetails[i];
                                <div class="carousel-item @(i == 0 ? "active" : "") text-center p-5" style="min-height: 400px;">
                                    <h4 class="text-white mb-3">@detail.Title</h4>
                                    @if (!string.IsNullOrEmpty(detail.Description))
                                    {
                                        <p class="text-light mb-4">@detail.Description</p>
                                    }
                                    <div class="d-inline-block bg-white p-2 rounded">
                                        @RenderMedia(detail.FileType, detail.FilePath)
                                    </div>
                                </div>
                            }
                        </div>
                        @if (Model.TopicDetails.Count > 1)
                        {
                            <button class="carousel-control-prev" type="button" data-bs-target="#topicCarousel" data-bs-slide="prev">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Previous</span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#topicCarousel" data-bs-slide="next">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                <span class="visually-hidden">Next</span>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    public Microsoft.AspNetCore.Html.IHtmlContent RenderMedia(string fileType, string filePath)
    {
        if (string.IsNullOrEmpty(filePath)) return Html.Raw("<p class='text-muted'>No media available.</p>");

        switch (fileType)
        {
            case "YouTube":
                // Extract video ID if it's a full URL
                string embedUrl = filePath;
                if (filePath.Contains("watch?v="))
                    embedUrl = filePath.Replace("watch?v=", "embed/");
                else if (filePath.Contains("youtu.be/"))
                    embedUrl = filePath.Replace("youtu.be/", "youtube.com/embed/");

                return Html.Raw($"<div class='ratio ratio-16x9 mx-auto' style='max-width: 800px;'><iframe src='{embedUrl}' title='YouTube video' allowfullscreen></iframe></div>");

            case "Video":
                return Html.Raw($"<video width='100%' style='max-width: 800px;' controls><source src='{filePath}' type='video/mp4'>Your browser does not support the video tag.</video>");

            case "Image":
                return Html.Raw($"<img src='{filePath}' class='img-fluid rounded shadow-sm' style='max-height: 500px;' alt='Topic Image' />");

            case "PDF":
                return Html.Raw($"<div class='ratio ratio-4x3 mx-auto' style='max-width: 800px;'><iframe src='{filePath}' title='PDF Document'></iframe></div><div class='mt-2'><a href='{filePath}' target='_blank' class='btn btn-outline-primary btn-sm'><i class='bi bi-box-arrow-up-right'></i> Open PDF in new tab</a></div>");

            case "URL":
                return Html.Raw($"<div class='text-center p-5'><i class='bi bi-link-45deg display-1 text-primary'></i><br/><br/><a href='{filePath}' target='_blank' class='btn btn-primary btn-lg rounded-pill px-4'>Click Here to Open Resource</a></div>");

            default:
                return Html.Raw($"<a href='{filePath}' target='_blank' class='btn btn-outline-secondary'>View Resource</a>");
        }
    }
}
