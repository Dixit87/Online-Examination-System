@model IEnumerable<Online_Examination_System.Models.Chapter>
@{
    ViewData["Title"] = "Chapters - " + ViewBag.SessionTitle;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="h3 mb-1 text-gray-800 font-weight-800">@ViewBag.SessionTitle</h1>
        <p class="text-muted mb-0">Select a chapter to view its topics.</p>
    </div>
    <a href="@Url.Action("Sessions")" class="btn btn-sm btn-outline-secondary rounded-pill px-3 py-2 shadow-sm">
        <i class="bi bi-arrow-left"></i> Back to Sessions
    </a>
</div>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var chapter in Model)
        {
            <div class="col-xl-4 col-md-6 mb-4">
                <div class="card premium-card border-0 shadow-sm h-100 hover-lift">
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="icon-circle bg-success-subtle text-success">
                                <i class="bi bi-journal-bookmark-fill fs-4"></i>
                            </div>
                        </div>
                        <h5 class="fw-bold text-dark mb-2">@chapter.Title</h5>
                        <p class="text-muted small flex-grow-1">
                            @(string.IsNullOrEmpty(chapter.Description) ? "No description available." : chapter.Description)
                        </p>
                        <a href="@Url.Action("Topics", new { chapterId = chapter.Id })" class="btn btn-outline-success btn-sm rounded-pill mt-3 fw-bold w-100">
                            View Topics <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-info border-0 shadow-sm rounded-4 text-center p-5">
                <i class="bi bi-journal-x display-4 text-info mb-3 d-block"></i>
                <h5 class="fw-bold">No Chapters Found</h5>
                <p class="text-muted">There are currently no chapters available for this session.</p>
            </div>
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>
