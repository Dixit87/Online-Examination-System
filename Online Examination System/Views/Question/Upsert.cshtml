@model Online_Examination_System.ViewModels.QuestionUpsertViewModel
@{
    ViewData["Title"] = Model.QuestionId == 0 ? "Create Question" : "Edit Question";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">@(Model.QuestionId == 0 ? "Create New Question" : "Edit Question")</h1>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-pill px-3 py-2 shadow-sm">
        <i class="bi bi-arrow-left"></i> Back to Questions
    </a>
</div>

<div class="row">
    <div class="col-xl-12 col-lg-12">
        <form asp-action="Upsert" method="post" id="questionForm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="QuestionId" />

            <div class="card premium-card mb-4 shadow-sm border-0">
                <div class="card-header py-3 bg-white border-0 border-bottom">
                    <h6 class="m-0 font-weight-bold text-primary">Question Master</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="QuestionText" class="form-label fw-bold">Question Title <span class="text-danger">*</span></label>
                        <textarea asp-for="QuestionText" class="form-control" rows="3" placeholder="Enter your question here..."></textarea>
                        <span asp-validation-for="QuestionText" class="text-danger small"></span>
                    </div>

                    <div class="mb-2 form-check form-switch">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" id="activeSwitch">
                        <label class="form-check-label fw-bold text-dark" for="activeSwitch">Question is Active</label>
                    </div>
                </div>
            </div>

            <div class="card premium-card mb-4 shadow-sm border-0">
                <div class="card-header py-3 bg-white border-0 border-bottom d-flex justify-content-between align-items-center">
                    <h6 class="m-0 font-weight-bold text-primary">Question Details (Options)</h6>
                    <button type="button" class="btn btn-sm btn-success rounded-pill px-3" onclick="addOptionRow()">
                        <i class="bi bi-plus-circle"></i> Add Option
                    </button>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle mb-0" id="optionsTable">
                            <thead class="table-light">
                                <tr>
                                    <th width="10%" class="text-center">Correct</th>
                                    <th width="80%">Option Text</th>
                                    <th width="10%" class="text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody id="optionsContainer">
                                @if (Model.Options != null && Model.Options.Count > 0)
                                {
                                    for (int i = 0; i < Model.Options.Count; i++)
                                    {
                                        <tr class="option-row">
                                            <td class="text-center">
                                                <input type="radio" name="CorrectOptionIndex" class="form-check-input correct-radio" value="@i" @(Model.CorrectOptionIndex == i ? "checked" : "") required />
                                            </td>
                                            <td>
                                                <input asp-for="Options[i].OptionId" type="hidden" class="option-id" />
                                                <input asp-for="Options[i].IsCorrect" type="hidden" class="is-correct-hidden" />
                                                <input asp-for="Options[i].OptionText" class="form-control option-text" placeholder="Enter option text..." required />
                                                <span asp-validation-for="Options[i].OptionText" class="text-danger small"></span>
                                            </td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeOptionRow(this)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mb-5 text-end">
                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm fw-bold">
                    <i class="bi bi-save me-1"></i> Save Question
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        function addOptionRow() {
            var container = document.getElementById("optionsContainer");
            var rowCount = container.getElementsByClassName("option-row").length;
            
            var tr = document.createElement("tr");
            tr.className = "option-row";
            
            tr.innerHTML = `
                <td class="text-center">
                    <input type="radio" name="CorrectOptionIndex" class="form-check-input correct-radio" value="${rowCount}" required />
                </td>
                <td>
                    <input type="hidden" name="Options[${rowCount}].OptionId" value="0" class="option-id" />
                    <input type="hidden" name="Options[${rowCount}].IsCorrect" value="false" class="is-correct-hidden" />
                    <input type="text" name="Options[${rowCount}].OptionText" class="form-control option-text" placeholder="Enter option text..." required />
                </td>
                <td class="text-center">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeOptionRow(this)">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            `;
            
            container.appendChild(tr);
            reindexRows();
        }
        
        function removeOptionRow(btn) {
            var row = btn.closest("tr");
            var container = document.getElementById("optionsContainer");
            
            if (container.getElementsByClassName("option-row").length <= 2) {
                alert("A question must have at least 2 options.");
                return;
            }
            
            row.remove();
            reindexRows();
        }
        
        function reindexRows() {
            var rows = document.getElementsByClassName("option-row");
            for (var i = 0; i < rows.length; i++) {
                var row = rows[i];
                
                // Update Radio Button Value
                var radio = row.querySelector(".correct-radio");
                if(radio) radio.value = i;
                
                // Update Name attributes
                var optionIdInput = row.querySelector(".option-id");
                if(optionIdInput) optionIdInput.name = "Options[" + i + "].OptionId";
                
                var isCorrectHidden = row.querySelector(".is-correct-hidden");
                if(isCorrectHidden) isCorrectHidden.name = "Options[" + i + "].IsCorrect";
                
                var optionTextInput = row.querySelector(".option-text");
                if(optionTextInput) optionTextInput.name = "Options[" + i + "].OptionText";
            }
        }
    </script>
}
