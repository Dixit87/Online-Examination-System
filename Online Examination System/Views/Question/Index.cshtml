@model IEnumerable<Online_Examination_System.Models.Question>
@{
    ViewData["Title"] = "Question Management";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Question Management</h1>
    <div class="d-flex gap-2">
        <a asp-action="BulkUpload" class="btn btn-sm btn-outline-success shadow-sm rounded-pill px-3 py-2 fw-bold">
            <i class="bi bi-file-earmark-excel text-success"></i> Bulk Upload
        </a>
        <a asp-action="Analytics" class="btn btn-sm btn-outline-info shadow-sm rounded-pill px-3 py-2 fw-bold">
            <i class="bi bi-graph-up text-info"></i> View Analytics
        </a>
        <a asp-action="Upsert" class="btn btn-sm btn-primary shadow-sm rounded-pill px-3 py-2">
            <i class="bi bi-plus-circle fa-sm text-white-50"></i> Create New Question
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm rounded-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card premium-card mb-4">
    <div class="card-header py-3 bg-white border-0 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary">All Questions</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table id="dataTable" class="table table-hover align-middle mb-0 border-white">
                <thead class="table-light">
                    <tr>
                        <th width="50%">Question Title</th>
                        <th>Options</th>
                        <th>Created Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-bold text-dark text-truncate" style="max-width: 400px;" title="@item.QuestionText">
                                        @item.QuestionText
                                    </div>
                                </td>
                                <td><span class="badge bg-info rounded-pill px-3 py-2">@item.OptionsCount Options</span></td>
                                <td>@item.CreatedDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <form asp-action="ToggleStatus" asp-route-id="@item.QuestionId" method="post" class="m-0 p-0">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" role="switch" onchange="this.form.submit()" @(item.IsActive ? "checked" : "")>
                                        </div>
                                    </form>
                                </td>
                                <td>
                                    <a asp-action="Upsert" asp-route-id="@item.QuestionId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                "pageLength": 10,
                "ordering": true,
                "info": true
            });
        });
    </script>
}
