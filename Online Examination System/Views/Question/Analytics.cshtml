@model IEnumerable<Online_Examination_System.ViewModels.QuestionAnalyticsViewModel>
@{
    ViewData["Title"] = "Question Analytics";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800 font-weight-800">Question Analytics</h1>
    <a href="@Url.Action("Index", "Question")" class="d-none d-sm-inline-block btn btn-sm btn-outline-secondary shadow-sm rounded-pill px-3 py-2">
        <i class="bi bi-arrow-left fa-sm me-1"></i> Back to Questions
    </a>
</div>

<div class="row">
    <div class="col-xl-12 col-lg-12">
        <div class="card premium-card shadow-sm border-0 mb-4">
            <div class="card-header py-3 bg-white border-0 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Difficulty & Performance Metrics</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive mt-3">
                    <table id="dataTable" class="table table-hover align-middle mb-0 border-white">
                        <thead class="table-light">
                            <tr>
                                <th>Question ID</th>
                                <th width="40%">Question Text</th>
                                <th>Total Attempts</th>
                                <th class="text-success">Correct</th>
                                <th class="text-danger">Wrong</th>
                                <th>Difficulty Index</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var q in Model)
                            {
                                <tr>
                                    <td>@q.QuestionId</td>
                                    <td>
                                        <div class="text-truncate fw-bold text-dark" style="max-width: 400px;" title="@q.QuestionText">
                                            @q.QuestionText
                                        </div>
                                    </td>
                                    <td>@q.TotalAttempts</td>
                                    <td class="text-success fw-bold">@q.TotalCorrect</td>
                                    <td class="text-danger fw-bold">@q.TotalWrong</td>
                                    <td>
                                        @if (q.TotalAttempts == 0)
                                        {
                                            <span class="badge bg-secondary">Not Attempted</span>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center">
                                                <span class="me-2">@q.DifficultyIndex.ToString("0.0")%</span>
                                                <div>
                                                    <div class="progress" style="width: 100px; height: 8px;">
                                                        <div class="progress-bar @(q.DifficultyIndex > 70 ? "bg-danger" : q.DifficultyIndex > 30 ? "bg-warning" : "bg-success")" role="progressbar" style="width: @q.DifficultyIndex%" aria-valuenow="@q.DifficultyIndex" aria-valuemin="0" aria-valuemax="100"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <small class="text-muted">
                                                @(q.DifficultyIndex > 70 ? "(Hard)" : q.DifficultyIndex > 30 ? "(Medium)" : "(Easy)")
                                            </small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#dataTable').DataTable({
                "pageLength": 25,
                "ordering": true,
                "order": [[5, "desc"]], // Sort by Difficulty Index descending
                "info": true
            });
        });
    </script>
}
