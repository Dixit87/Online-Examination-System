@{
    ViewData["Title"] = "Server Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-danger opacity-50" style="font-size: 8rem;"></i>
            </div>
            <h1 class="display-1 fw-bold text-danger mb-3">500</h1>
            <h2 class="h3 fw-bold text-dark mb-4">Internal Server Error</h2>
            <p class="text-muted fs-5 mb-5">Something went wrong on our end. We are working on fixing it. Please try again later.</p>
            
            <div class="d-flex justify-content-center gap-3">
                <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-5 py-3 fw-bold shadow-sm">
                    <i class="bi bi-arrow-left me-2"></i> Go Back
                </a>
                <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow">
                    <i class="bi bi-house-door-fill me-2"></i> Return to Homepage
                </a>
            </div>
        </div>
    </div>
</div>
