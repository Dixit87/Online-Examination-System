@{
    ViewData["Title"] = "Page Not Found";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-4">
                <i class="bi bi-emoji-frown-fill text-primary opacity-50" style="font-size: 8rem;"></i>
            </div>
            <h1 class="display-1 fw-bold text-primary mb-3">404</h1>
            <h2 class="h3 fw-bold text-dark mb-4">Oops! Page not found.</h2>
            <p class="text-muted fs-5 mb-5">The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.</p>
            
            <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow">
                <i class="bi bi-house-door-fill me-2"></i> Return to Homepage
            </a>
        </div>
    </div>
</div>
